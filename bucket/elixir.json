{
    "version": "1.20.2",
    "description": "A dynamic and functional programming language designed for building scalable and maintainable applications. Built on latest OTP",
    "homepage": "https://elixir-lang.org/",
    "license": "Apache-2.0",
    "url": "https://github.com/elixir-lang/elixir/releases/download/v1.20.2/elixir-otp-29.zip",
    "hash": "a9e88cd41fbbba7da6f6dc237a49dd2ed4e70457121035cc7fc56ad05582f394",
    "env_add_path": "bin",
    "suggest": {
        "Erlang": "erlang"
    },
    "checkver": {
        "script": [
            "$responseRelease = (Invoke-WebRequest -Headers @{'Accept'='applications/vnd.github+json';'X-Github-Api-Version'='2022-11-28';'Authorization'=\"Bearer $env:GH_TOKEN\"} -Uri 'https://api.github.com/repos/elixir-lang/elixir/releases/latest').Content | ConvertFrom-Json",
            "$responseRelease.tag_name -match '^v(?<version>[\\d.]+)$'",
            "$version = $Matches.version",
            "$assetUrl = $responseRelease.assets_url + '?per_page=100'",
            "$responseAssets = (Invoke-WebRequest -Headers  @{'Accept'='applications/vnd.github+json';'X-Github-Api-Version'='2022-11-28';'Authorization'=\"Bearer $env:GH_TOKEN\"} -Uri $assetUrl).Content | ConvertFrom-Json",
            "$otpVersion = ($responseAssets |foreach{if($_.name -match '^elixir-otp-(?<otpversion>\\d+).zip$') {$Matches.otpversion}} |measure -Maximum).Maximum",
            "Write-Output $version $otpVersion"
        ],
        "regex": "(?<version>[\\d.]+)\\s(?<otpversion>.+)"
    },
    "autoupdate": {
        "url": "https://github.com/elixir-lang/elixir/releases/download/v$version/elixir-otp-$matchOtpversion.zip",
        "hash": {
            "url": "https://github.com/elixir-lang/elixir/releases/download/v$version/elixir-otp-$matchOtpversion.zip.sha256sum"
        }
    }
}
